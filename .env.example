# Copier ce fichier en .env.local et remplir les valeurs

# Base de données PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/gibbons_db?schema=public"

# NextAuth.js — générer avec : openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-replace-in-production"

# URL de l'application
NEXTAUTH_URL="http://localhost:3000"
